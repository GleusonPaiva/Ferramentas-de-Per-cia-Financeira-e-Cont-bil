# Exemplo de Variáveis de Ambiente para Perícia Judicial
# Copie este arquivo para .env e preencha com seus caminhos locais

# Caminho para documentos de processos (PDFs)
DIRETORIO_PROCESSOS=C:/Users/seu_usuario/Pasta_Do_Processo/processos

# Caminho para bases de dados reais (Planilhas de Cálculos)
DIRETORIO_DADOS=C:/Users/seu_usuario/Pasta_Do_Processo/dados

# Credenciais de acesso (se houver necessidade de banco de dados local ou APIs)
CHAVE_API_EXEMPLO=seu_token_aqui
